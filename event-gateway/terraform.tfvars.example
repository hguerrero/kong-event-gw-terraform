# ============================================================================
# Konnect Configuration
# ============================================================================
# Copy this file to terraform.tfvars and fill in your values

konnect_server_url = "https://us.api.konghq.com"
# konnect_token      = "YOUR_KONNECT_PAT"

# ============================================================================
# Kong Identity Configuration
# ============================================================================

auth_server_name        = "Kafka Auth Dev"
auth_server_audience    = "tcp://localhost:9092"
auth_server_description = "Auth server for the dev environment"

scope_name        = "kafka"
scope_description = "Scope to test Kong Identity"

client_name_1 = "Client 1"
client_name_2 = "Client 2"

access_token_duration = 3600
id_token_duration     = 3600

# ============================================================================
# Event Gateway Configuration
# ============================================================================

event_gateway_name        = "kong-event-gateway-terraform"
event_gateway_description = "Event Gateway for the dev environment managed by Terraform"

backend_cluster_bootstrap_servers = [
  "kafka1:9092",
  "kafka2:9092",
  "kafka3:9092"
]
