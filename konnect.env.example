# Copy to konnect.env and fill values before running docker compose
# See "Environment Bootstrap" section for step-by-step instructions.

# ── Konnect connection ────────────────────────────────────────────────────────
KONG_KONNECT_REGION=us        # e.g. us, eu, au
KONG_KONNECT_DOMAIN=konghq.com

# Gateway cluster ID — obtained after applying terraform
# After running `terraform apply`, populate konnect.env automatically with:
#   cd event-gateway && terraform output -raw konnect_env_snippet >> ../konnect.env
KONG_KONNECT_GATEWAY_CLUSTER_ID=<your-cluster-id>

# ── Data plane TLS identity ───────────────────────────────────────────────────
# Certificates are generated and registered automatically by Terraform.
# After `terraform apply`, run the following to populate this file:
#
#   cd event-gateway
#   terraform output -raw konnect_env_snippet >> ../konnect.env
#
# This writes KONG_KONNECT_GATEWAY_CLUSTER_ID, KONG_KONNECT_CLIENT_CERT, and
# KONG_KONNECT_CLIENT_KEY into konnect.env in one step.  The PEM files are
# also written to config/certs/ for reference (tls.crt and key.crt).
#
# Manual generation (alternative, no Terraform):
#   openssl req -new -x509 -nodes -newkey rsa:2048 \
#     -subj "/CN=event-gateway/C=US" \
#     -keyout config/certs/key.crt \
#     -out    config/certs/tls.crt
#
KONG_KONNECT_CLIENT_CERT="<paste tls.crt PEM content here, or use terraform output>"
KONG_KONNECT_CLIENT_KEY="<paste key.crt PEM content here, or use terraform output>"

# ── Optional ─────────────────────────────────────────────────────────────────
# KAFKA_USERNAME=                           # Required for Confluent Cloud variant
# KAFKA_PASSWORD=                           # Required for Confluent Cloud variant
# TRANSACTION_ENCRYPTION_KEY=               # Required for Phases 4-5
#   export TRANSACTION_ENCRYPTION_KEY=$(openssl rand -base64 32)
